{
  "manifest_version": 3,
  "name": "RAG Context Translator",
  "version": "1.0.0",
  "description": "Dịch thuật thông minh dựa trên ngữ cảnh toàn trang web.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://agentproject-backend-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "RAG Translator"
  },
  
  "icons": {
    "128": "images.png"
  }
}
